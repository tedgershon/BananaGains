# Copy to `.env`. See README and `backend/config.py` (`Settings`) for meanings.
supabase_url=
supabase_key=
supabase_service_role_key=
supabase_jwt_secret=

# CORS_ORIGINS expects JSON unless you rely on defaults in Settings.
# cors_origins=["http://localhost:3000"]

# Sentry — leave SENTRY_DSN unset locally to disable the SDK (no network).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
