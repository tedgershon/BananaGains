# Copy to `.env.local` for local Next.js overrides (see README).
# Supabase connection (leave unset for demo-user mode in Sprint 1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI backend URL (defaults to http://localhost:8000 when unset)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry — use production DSNs only in Vercel / secrets, not committed values.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
